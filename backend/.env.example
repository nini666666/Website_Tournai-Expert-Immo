# ─── Tournai Expert Immo — Variables d'environnement ───────────────
# Copier ce fichier en .env et remplir les valeurs

# ─── Google OAuth2 ────────────────────────────────────────────────
# Obtenir sur https://console.cloud.google.com
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ID du calendrier Google (laisser "primary" pour le calendrier principal)
GOOGLE_CALENDAR_ID=primary

# ─── Gmail SMTP ───────────────────────────────────────────────────
# Compte Gmail utilisé pour envoyer les emails
GMAIL_USER=expertimmotournai@gmail.com

# Mot de passe d'application (PAS le mot de passe Gmail normal)
# Générer sur : https://myaccount.google.com/apppasswords
# (nécessite la validation en 2 étapes activée)
GMAIL_APP_PASS=VOTRE_MOT_DE_PASSE_APPLICATION

# ─── Serveur ──────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://tournaiexpertimmo.be
